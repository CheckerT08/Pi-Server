<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Vocab</title>

  <link rel="stylesheet" href="/css/main.css">
  <script src="/js/vocab_add.js" type="module"></script>
</head>

<body>

  <h1>Add Vocab</h1>

  <form id="addVocabForm" autocomplete="off">
    <textarea
      autocomplete="off"
      name="vocab" 
      placeholder="Deutsch,Andere" 
      required></textarea>

    <button type="submit">Hinzufügen</button>
  </form>
  
  <h1>Alle Vocabs</h1>

  <table class="vocab-table">
    <thead>
      <tr>
        <th>Deutsch</th>
        <th>Andere</th>
        <th>Aktionen</th>
      </tr>
    </thead>

    <tbody>
      <% Object.entries(vocab).forEach(([de, other]) => { %>
        <tr data-id="<%= de %>">
          <td><%= de %></td>
          <td><%= other %></td>
          <td>
            <button class="deleteBtn">DELETE</button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

</body>
</html>